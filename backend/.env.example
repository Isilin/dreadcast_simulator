# Variables d'environnement du backend NestJS
# Copiez ce fichier en .env et remplissez les valeurs

# URL Supabase de votre projet
SIMULATOR_SUPABASE_URL=https://votre-projet.supabase.co

# Clé anonyme Supabase (publique)
SIMULATOR_SUPABASE_ANON_KEY=votre_cle_anon

# Port d'écoute du serveur (optionnel, défaut : 3000)
PORT=3000
